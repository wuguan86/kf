# --- Dependencies ---
node_modules/
.pnpm-debug.log*

# --- Build Outputs ---
# Electron-vite 默认输出目录
dist/
dist-ssr/
# Electron-builder/Forge 默认打包输出目录 (你截图中出现了红色状态的 out 文件夹)
out/
release/
*.asar

# --- Logs ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Environment Variables ---
# 建议忽略本地环境配置文件，防止泄露密钥
.env.local
.env.development.local
.env.testing.local
.env.production.local
# 如果 .env.development 包含敏感信息（如 API Key），也建议忽略
# .env.development
# .env.production

# --- IDE & Editors ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# 针对 Trae 编辑器的配置文件夹 (你截图中有的)
.trae/

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- TypeScript ---
*.tsbuildinfo