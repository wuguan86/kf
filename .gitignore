# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.iml
.trae/

# 忽略 Maven 编译生成的目录（最重要）
target/

# 忽略 application.yml 的配置
application.yml
application-dev.yml
application-prod.yml



# 忽略数据库文件
*.sql

# 忽略操作系统生成的临时文件
bin/
tmp/
.DS_Store
Thumbs.db

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.venv/
venv/
ENV/

# --- Build & Distribution (PyInstaller等打包产物) ---
build/
dist/
# 如果你的 .spec 文件是自动生成的，可以忽略；如果是手写的配置，请删掉下面这一行
# *.spec

# --- Logs & Debug Outputs (自动化产生的日志和中间文件) ---
*.log
wechat_bridge.log
@AutomationLog.txt
inspect_output.txt
控件树.txt
debug_view.png

# --- Configuration (包含敏感信息的配置文件) ---
# 建议只保留一个 config.example.yaml 在 Git 里，真实的配置忽略掉
config_dev.yaml
config_prod.yaml
config.yaml  # 如果里面有密码或Token，建议也忽略



# --- Dependencies ---
node_modules/
.pnpm-debug.log*

# --- Build Outputs ---
# Electron-vite 默认输出目录
dist/
dist-ssr/
# Electron-builder/Forge 默认打包输出目录 (你截图中出现了红色状态的 out 文件夹)
out/
release/
*.asar

# --- Logs ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Environment Variables ---
# 建议忽略本地环境配置文件，防止泄露密钥
.env.local
.env.development.local
.env.testing.local
.env.production.local
# 如果 .env.development 包含敏感信息（如 API Key），也建议忽略
# .env.development
# .env.production



# --- TypeScript ---
*.tsbuildinfo